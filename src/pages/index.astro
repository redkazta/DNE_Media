---
import Layout from "../layouts/Layout.astro";
import { aboutCopy, managementProfiles, portfolioCategories, roster, services } from "../data/siteContent";
---

<Layout title="DNE Media">
  <!-- Hero Section with Spotlight Effect -->
  <section class="relative flex min-h-[50vh] flex-col justify-end pb-12 md:pb-16 overflow-hidden">
    <!-- Ambient Background Glow -->
    <div class="absolute top-[-20%] right-[-10%] h-[500px] w-[500px] rounded-full bg-white/[0.03] blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] left-[-20%] h-[400px] w-[400px] rounded-full bg-white/[0.02] blur-[80px] pointer-events-none"></div>

    <div class="max-w-3xl relative z-10">
      <span class="block mb-4 text-[10px] font-bold tracking-[0.4em] uppercase text-white/40 animate-fade-in">Production & Management</span>
      <h1 class="font-serif text-3xl leading-tight text-white md:text-4xl lg:text-5xl text-balance tracking-tighter">
        <span class="block animate-fade-in delay-100">{aboutCopy[0].split(' ').slice(0, 4).join(' ')}</span>
        <span class="block animate-fade-in delay-200 text-white/50">{aboutCopy[0].split(' ').slice(4).join(' ')}</span>
      </h1>
      <p class="mt-4 max-w-lg text-sm leading-relaxed text-white/60 md:text-base font-light animate-fade-in delay-300">
        {aboutCopy[1]}
      </p>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 right-0 animate-fade-in delay-500 hidden md:block">
      <div class="flex items-center gap-4">
        <span class="text-[10px] tracking-[0.3em] uppercase text-white/30 rotate-90 origin-right translate-x-2">Scroll</span>
        <div class="h-12 w-[1px] bg-gradient-to-b from-white/0 via-white/20 to-white/0"></div>
      </div>
    </div>
  </section>

  <div class="mb-24 border-b border-white/10"></div>

  <!-- Services: Interactive List -->
  <section class="mb-24">
    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
      <h2 class="font-serif text-2xl text-white/50 md:text-3xl sticky top-24 self-start mix-blend-difference">Services</h2>
      <ul class="space-y-px">
        {services.map((service, index) => (
          <li class="group relative flex items-center justify-between border-t border-white/10 py-6 transition-all duration-500 hover:border-white/40 hover:pl-6">
            <span class="absolute left-0 top-1/2 -translate-y-1/2 text-6xl font-serif leading-none text-white/[0.02] transition-transform duration-700 group-hover:translate-x-24 group-hover:scale-110 pointer-events-none select-none">0{index + 1}</span>
            <span class="relative z-10 text-xl font-light text-white/70 transition-colors duration-300 group-hover:text-white md:text-2xl">{service}</span>
            <span class="relative z-10 text-[10px] tracking-widest text-white/30 opacity-0 transition-all duration-300 group-hover:opacity-100">EXPLORE</span>
          </li>
        ))}
        <li class="border-t border-white/10"></li>
      </ul>
    </div>
  </section>

  <!-- Portfolio: Masonry-style Grid -->
  <section class="mb-24">
    <div class="grid gap-12 lg:grid-cols-[1fr_2fr]">
      <h2 class="font-serif text-2xl text-white/50 md:text-3xl sticky top-24 self-start mix-blend-difference">Selected Work</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {portfolioCategories.map((category, i) => (
          <a href={`/${category.slug}`} class={`group relative block aspect-[3/4] overflow-hidden bg-neutral-900 transition-transform duration-700 hover:-translate-y-4 ${i % 2 === 1 ? 'mt-8' : ''}`}>
            <div class="absolute inset-0 z-10 flex flex-col justify-between p-6 bg-gradient-to-b from-transparent via-transparent to-black/90 opacity-80 transition-opacity duration-500 group-hover:opacity-100">
              <span class="self-end text-[10px] font-bold tracking-widest uppercase text-white/40 border border-white/20 px-3 py-1 rounded-full backdrop-blur-sm transition-colors group-hover:border-white/60 group-hover:text-white">View</span>
              <div>
                <span class="block text-[10px] font-bold tracking-[0.2em] uppercase text-white/60 mb-2">Portfolio</span>
                <h3 class="font-serif text-2xl text-white italic">{category.label}</h3>
              </div>
            </div>
            <!-- Dynamic Placeholder Pattern -->
            <div class="absolute inset-0 opacity-20 transition-transform duration-1000 group-hover:scale-110" style={`background-image: radial-gradient(circle at center, white 1px, transparent 1px); background-size: ${20 + i * 5}px ${20 + i * 5}px;`}></div>
            <div class="absolute inset-0 bg-white/5 mix-blend-overlay transition-colors duration-500 group-hover:bg-white/10"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Management: Horizontal Scroll / Cards -->
  <section class="mb-24">
    <div class="grid gap-8 lg:grid-cols-[1fr_3fr]">
      <h2 class="font-serif text-2xl text-white/50 md:text-3xl sticky top-24 self-start mix-blend-difference">Management</h2>
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
        {managementProfiles.map((profile) => (
          <a href={`/${profile.slug}`} class="group relative aspect-[3/4] overflow-hidden bg-neutral-900 border border-white/10">
            <img 
              src={profile.image} 
              alt={profile.label} 
              class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105 opacity-60 group-hover:opacity-100 grayscale group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 transition-opacity duration-500 group-hover:opacity-60"></div>
            <div class="absolute bottom-0 left-0 w-full p-4 transition-transform duration-500 group-hover:-translate-y-1">
              <h3 class="font-serif text-xl text-white tracking-tight">{profile.label}</h3>
              <p class="text-[9px] uppercase tracking-widest text-white/50 mt-1 opacity-80 group-hover:text-white/80">Exclusive</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Roster: Typographic Cloud -->
  <section class="mb-24 relative">
    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.02] to-transparent pointer-events-none"></div>
    <div class="relative z-10 py-16 text-center">
      <h2 class="mb-12 font-serif text-xs font-bold tracking-[0.4em] uppercase text-white/30">Complete Roster</h2>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-6 max-w-5xl mx-auto px-4">
        {roster.map((artist) => (
          <span class="text-lg text-white/40 transition-all duration-300 hover:text-white hover:scale-110 md:text-2xl font-serif italic cursor-crosshair">{artist}</span>
        ))}
      </div>
    </div>
  </section>
</Layout>
