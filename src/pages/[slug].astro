---
import Layout from "../layouts/Layout.astro";
import { managementProfiles, pages, portfolioCategories } from "../data/siteContent";

export function getStaticPaths() {
  const slugs = new Set([
    ...portfolioCategories.map((item) => item.slug),
    ...managementProfiles.map((item) => item.slug)
  ]);

  return Array.from(slugs).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const category = portfolioCategories.find((item) => item.slug === slug);
const profile = managementProfiles.find((item) => item.slug === slug);
const page = pages.find((item) => item.slug === slug);

const pageLabel = category?.label ?? profile?.label ?? slug;
const pageTitle = page?.title ?? `${pageLabel} | DNE Media`;
const typeLabel = category ? "Portfolio" : "Artist";
---

<Layout title={pageTitle}>
  <section class="relative min-h-[30vh] flex flex-col justify-end pb-8 overflow-hidden border-b border-white/10 mb-8">
    <!-- Ambient Background -->
    <div class="absolute top-0 right-0 h-[300px] w-[300px] rounded-full bg-white/[0.02] blur-[80px] pointer-events-none"></div>

    <div class="relative z-10">
      <a href="/artists" class="group mb-4 inline-flex items-center text-[10px] uppercase tracking-[0.2em] text-white/40 transition-colors hover:text-white">
        <span class="mr-2 transition-transform group-hover:-translate-x-1">←</span> Back to Artists
      </a>
      
      <div class="border-l border-white/20 pl-6 animate-fade-in">
        <p class="mb-2 text-[10px] font-bold tracking-[0.4em] uppercase text-white/50">{typeLabel}</p>
        <h1 class="font-serif text-3xl leading-tight text-white md:text-5xl tracking-tighter mix-blend-difference">
          {pageLabel}
        </h1>
        {profile?.tags && (
          <div class="mt-3 flex flex-wrap gap-2">
            {profile.tags.map(tag => (
              <span class="text-[9px] uppercase tracking-wider border border-white/10 px-2 py-0.5 rounded-full text-white/60 bg-white/5">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
    
  <section class="w-full animate-fade-in delay-200">
      {profile ? (
        <div class="grid md:grid-cols-12 gap-8 items-start">
            <div class="md:col-span-4 relative aspect-[3/4] w-full overflow-hidden bg-neutral-900 border border-white/10 rounded-sm">
                {profile.image ? (
                    <img src={profile.image} alt={pageLabel} class="h-full w-full object-cover opacity-90 transition-all duration-700 hover:scale-105 grayscale hover:grayscale-0" loading="lazy" />
                ) : (
                    <div class="absolute inset-0 flex items-center justify-center text-white/20">
                        <span class="text-xs tracking-widest uppercase">No Image</span>
                    </div>
                )}
            </div>
            
            <div class="md:col-span-8 flex flex-col gap-6">
                <div class="prose prose-invert prose-sm max-w-none">
                    <p class="text-white/80 text-sm leading-relaxed font-light whitespace-pre-line text-justify">
                        {profile.bio || "Biography coming soon."}
                    </p>
                </div>
                
                {profile.socials && (
                    <div class="border-t border-white/10 pt-6 mt-4">
                        <h3 class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/40 mb-3">Connect</h3>
                        <div class="flex flex-wrap gap-4">
                            {profile.socials.map(social => (
                                <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-xs text-white/60 hover:text-white transition-colors uppercase tracking-wider flex items-center gap-1 group">
                                    {social.label}
                                    <span class="opacity-0 -translate-y-1 transition-all group-hover:opacity-100 group-hover:translate-y-0">↗</span>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </div>
      ) : (
        <div class="mt-12 w-full">
            <div class="group relative aspect-video w-full overflow-hidden bg-neutral-900 border-y border-white/10">
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent z-10 opacity-80"></div>
                <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
                <img src="/hero-fallback.svg" alt={`${pageLabel} visual placeholder`} class="h-full w-full object-cover opacity-60 grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105 group-hover:opacity-80" loading="lazy" />
                <div class="absolute bottom-0 left-0 z-20 p-6 md:p-12">
                <p class="max-w-xl text-lg text-white/90 md:text-xl font-light leading-relaxed italic">
                    Explore our work in <span class="text-white font-normal">{pageLabel}</span>.
                </p>
                </div>
            </div>
        </div>
      )}
  </section>
</Layout>
