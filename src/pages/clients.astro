---
import Layout from "../layouts/Layout.astro";
import { roster } from "../data/siteContent";
---

<Layout title="Clients | DNE Media">
  <section>
    <p class="text-[10px] tracking-[0.28em] text-white/60 uppercase">CLIENTS</p>
    <h1 class="mt-4 font-serif text-2xl md:text-4xl text-white">Clients</h1>
    <ul class="mt-6 grid gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {roster.map((client) => (
        <li class="rounded border border-white/10 px-3 py-2 text-xs text-white/85">{client}</li>
      ))}
    </ul>
  </section>
</Layout>
